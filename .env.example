# =============================================================================
# Multiply — Swarm Outreach Engine (HappyRobot × TUM.ai)
# Copy to .env.local and fill in. Never commit real secrets.
# =============================================================================

# --- HappyRobot (EU region) ---------------------------------------------------
HR_API_KEY=
HR_WORKFLOW_SLUG=019d9cb9-416e-7404-be97-3d329afb1318
HR_BASE_URL=https://api.eu.happyrobot.ai/v2
HR_HOOKS_URL=https://platform.eu.happyrobot.ai/hooks
WEBHOOK_SECRET=

# --- Cognee (knowledge graph + vector memory) --------------------------------
# Self-hosted via docker-compose.cognee.yml (default), or Cognee Cloud.
COGNEE_API_URL=http://localhost:8000
COGNEE_API_KEY=
# OpenAI key cognee uses internally for LLM + embeddings (required for self-host).
COGNEE_LLM_API_KEY=

# --- HappyRobot Twin DB (workflow dump + learnings) ---------------------------
HR_TWIN_BASE_URL=
HR_TWIN_API_KEY=
HR_TWIN_WORKFLOW_DUMP_TABLE=workflow_dump
HR_TWIN_LEARNINGS_TABLE=learnings

# --- Supabase -----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# --- Google Calendar (booking tool) -------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
DEMO_CALENDAR_ID=

# --- Demo ---------------------------------------------------------------------
DEMO_PRODUCT_PROFILE_PATH=./scripts/product-profile.json
NEXT_PUBLIC_APP_URL=http://localhost:3000
