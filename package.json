{
  "name": "multiply",
  "version": "0.0.1",
  "private": true,
  "description": "Swarm Outreach Engine — HappyRobot × TUM.ai (Idea 1). Brain repo: ../HappyRobot-TumAI",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "cognee:up": "docker compose -f docker-compose.cognee.yml up -d",
    "cognee:down": "docker compose -f docker-compose.cognee.yml down",
    "cognee:logs": "docker compose -f docker-compose.cognee.yml logs -f cognee",
    "cognee:seed": "tsx scripts/seed-cognee.ts",
    "cognee:reset": "tsx scripts/seed-cognee.ts --reset"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "eventsource-parser": "^3.0.0",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.453.0",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
